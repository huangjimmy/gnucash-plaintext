#!/bin/bash
#
# Pre-commit hook: Run linter, tests, and independent AI review
#
# Flow:
#   1. Run lint (always)
#   2. Run tests via test-all-versions-parallel.sh (always, even if lint failed)
#   3. If lint OR tests failed → block immediately (no AI review = no wasted tokens)
#   4. If both passed → run AI review → block on concerns
#

echo "Running pre-commit checks..."
echo ""

LINT_FAILED=0
TEST_FAILED=0
LINT_OUTPUT=""
TEST_OUTPUT=""

# Check if Docker is available
if ! command -v docker > /dev/null 2>&1; then
    echo "⚠️  Docker not found - skipping linting and tests"
    echo "   Install Docker to enable pre-commit checks"
    echo ""
else
    # 1. Lint staged Python files
    echo "1. Running linting..."

    STAGED_PY_FILES=$(git diff --staged --name-only --diff-filter=ACM | grep '\.py$' | tr '\n' ' ' || true)

    if [ -z "$STAGED_PY_FILES" ]; then
        echo "⚠️  No Python files staged - skipping linting"
        echo ""
    else
        if ! LINT_OUTPUT=$(./scripts/lint.sh $STAGED_PY_FILES 2>&1); then
            LINT_FAILED=1
            echo "❌ Linting failed"
            echo ""
        else
            echo "✓ Linting passed"
            echo ""
        fi
    fi

    # 2. Run tests against all supported versions (always run, even if lint failed)
    echo "2. Running tests (all versions)..."
    if ! TEST_OUTPUT=$(./scripts/test-all-versions-parallel.sh 2>&1); then
        TEST_FAILED=1
        echo "❌ Tests failed"
        echo ""
    else
        echo "✓ Tests passed"
        echo ""
    fi

    # 3. Block immediately if lint or tests failed — skip AI review to save tokens
    if [ $LINT_FAILED -eq 1 ] || [ $TEST_FAILED -eq 1 ]; then
        if [ $LINT_FAILED -eq 1 ]; then
            echo "Linting errors:"
            echo "$LINT_OUTPUT"
            echo ""
            echo "Fix with: ./scripts/fix-lint.sh --unsafe"
            echo ""
        fi
        if [ $TEST_FAILED -eq 1 ]; then
            echo "Test failures (last 50 lines):"
            echo "$TEST_OUTPUT" | tail -50
            echo ""
        fi
        echo "❌ Commit blocked: fix lint/test failures before committing."
        exit 1
    fi
fi

# 4. AI review — only reached when lint + tests both pass
echo "3. Running independent AI review..."

STAGED_DIFF=$(git diff --staged --no-color)

if [ -z "$STAGED_DIFF" ]; then
    echo "⚠️  No staged changes - nothing to review"
    echo ""
    echo "✓ All pre-commit checks passed!"
    exit 0
fi

# Allow skipping AI review for quick commits
if [ "$SKIP_AI_REVIEW" = "1" ]; then
    echo "⚠️  AI review skipped (SKIP_AI_REVIEW=1)"
    echo "✓ All pre-commit checks passed!"
    exit 0
fi

# Check if claude command is available
if ! command -v claude > /dev/null 2>&1; then
    echo "⚠️  Claude Code not installed - skipping AI review"
    echo "✓ All pre-commit checks passed!"
    exit 0
fi

# Helper function: Build review input prompt
build_review_input() {
  echo "You are an independent code reviewer conducting a pre-commit review."
  echo ""
  echo "**IMPORTANT**: You have NOT seen the implementation process. You are reviewing this commit with fresh eyes from an outsider's perspective."
  echo ""
  echo "Your task:"
  echo "1. Understand what this commit is trying to do"
  echo "2. Verify the changes are correct and complete"
  echo "3. Check for: logic errors, missing edge cases, security issues, missing tests"
  echo "4. Output your decision:"
  echo "   - If issues found: Start your response with \"CONCERNS:\" and list specific issues"
  echo "   - If approved: Start your response with \"APPROVED:\" and briefly explain why"
  echo ""
  echo "Be concise but specific. Focus on real issues that would cause problems."
  echo ""
  echo "=== STAGED CHANGES ==="
  git diff --staged
}

# Helper function: Run command with timeout and CLAUDECODE unset.
# Saves and restores the git index so that any git operations performed
# by the AI reviewer session cannot contaminate the staged changes.
run_with_timeout() {
  unset CLAUDECODE
  local index_file
  index_file=$(git rev-parse --git-path index)
  local index_backup="${index_file}.pre-review-backup"
  cp "$index_file" "$index_backup"
  timeout 90s "$@"
  local exit_code=$?
  cp "$index_backup" "$index_file"
  rm -f "$index_backup"
  return $exit_code
}

echo "   (Tip: Set SKIP_AI_REVIEW=1 to skip for quick commits)"
echo "   Spawning independent AI reviewer (90s timeout)..."

REVIEW_OUTPUT=$(build_review_input | run_with_timeout claude 2>&1)
REVIEW_EXIT_CODE=$?

if [ $REVIEW_EXIT_CODE -eq 124 ]; then
    echo "⚠️  AI review timed out after 90 seconds - proceeding without review"
    echo "✓ All pre-commit checks passed!"
    exit 0
fi

if echo "$REVIEW_OUTPUT" | grep -q "^APPROVED:"; then
    echo "✓ AI review approved"
    echo "✓ All pre-commit checks passed!"
    exit 0
elif echo "$REVIEW_OUTPUT" | grep -q "^CONCERNS:"; then
    echo "❌ AI review found concerns:"
    echo ""
    echo "$REVIEW_OUTPUT"
    echo ""
    echo "Please address the concerns or use 'git commit --no-verify' to skip checks."
    exit 1
else
    # Unexpected output format — show it but don't block
    echo "⚠️  AI review output format unexpected - proceeding anyway"
    echo "$REVIEW_OUTPUT"
    echo ""
    echo "✓ All pre-commit checks passed!"
    exit 0
fi
