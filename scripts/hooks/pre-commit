#!/bin/bash
#
# Pre-commit hook: Run linter, tests, and independent AI review
#
# Flow: Linting/tests run but don't block → AI reviews actual code → Block if quality checks failed
#

echo "Running pre-commit checks..."
echo ""

# Track quality check results
LINT_FAILED=0
TEST_FAILED=0
LINT_OUTPUT=""
TEST_OUTPUT=""

# Check if Docker is available
if ! command -v docker > /dev/null 2>&1; then
    echo "⚠️  Docker not found - skipping linting and tests"
    echo "   Install Docker to enable pre-commit checks"
    echo ""
else
    # Run linter on staged Python files only (don't exit on failure, just record it)
    echo "1. Running linting..."

    # Get list of staged Python files
    STAGED_PY_FILES=$(git diff --staged --name-only --diff-filter=ACM | grep '\.py$' | tr '\n' ' ' || true)

    if [ -z "$STAGED_PY_FILES" ]; then
        echo "⚠️  No Python files staged - skipping linting"
        echo ""
    else
        # Use scripts/lint.sh to avoid duplicating Docker/ruff logic
        if ! LINT_OUTPUT=$(./scripts/lint.sh $STAGED_PY_FILES 2>&1); then
            LINT_FAILED=1
            echo "⚠️  Linting found issues in staged files (will block commit after review)"
            echo ""
        else
            echo "✓ Linting passed"
            echo ""
        fi
    fi

    # Run tests in Docker (don't exit on failure, just record it)
    # TODO: Re-enable ubuntu20 testing after verifying Docker image builds correctly
    echo "2. Running tests..."
    if ! TEST_OUTPUT=$(./scripts/test.sh 2>&1); then
        TEST_FAILED=1
        echo "⚠️  Tests failed (will block commit after review)"
        echo ""
    else
        echo "✓ Tests passed"
        echo ""
    fi
fi

# Run independent AI review
echo "3. Running independent AI review..."

# Get staged changes
STAGED_DIFF=$(git diff --staged --no-color)

if [ -z "$STAGED_DIFF" ]; then
    echo "⚠️  No staged changes - nothing to review"
    echo ""
    echo "✓ All pre-commit checks passed!"
    exit 0
fi

# Allow skipping AI review for quick commits
if [ "$SKIP_AI_REVIEW" = "1" ]; then
    echo "⚠️  AI review skipped (SKIP_AI_REVIEW=1)"
    echo ""
    # Still enforce quality checks
    if [ $LINT_FAILED -eq 1 ] || [ $TEST_FAILED -eq 1 ]; then
        echo "❌ Commit blocked: Quality checks failed"
        [ $LINT_FAILED -eq 1 ] && echo "   - Fix linting with: ./scripts/fix-lint.sh --unsafe"
        [ $TEST_FAILED -eq 1 ] && echo "   - Fix tests with: ./scripts/test.sh"
        exit 1
    fi
    echo "✓ All pre-commit checks passed!"
    exit 0
fi

# Check if claude command is available
if ! command -v claude > /dev/null 2>&1; then
    echo "⚠️  Claude Code not installed - skipping AI review"
    echo "   Install Claude Code to enable AI-powered commit reviews"
    echo ""
    echo "✓ All pre-commit checks passed!"
    exit 0
fi

# Helper function: Build review input prompt
build_review_input() {
  echo "You are an independent code reviewer conducting a pre-commit review."
  echo ""
  echo "**IMPORTANT**: You have NOT seen the implementation process. You are reviewing this commit with fresh eyes from an outsider's perspective."
  echo ""
  echo "Your task:"
  echo "1. Understand what this commit is trying to do"
  echo "2. Verify the changes are correct and complete"
  echo "3. Check for: logic errors, missing edge cases, security issues, missing tests"
  echo "4. Consider linting/test results shown below"
  echo "5. Output your decision:"
  echo "   - If issues found: Start your response with \"CONCERNS:\" and list specific issues"
  echo "   - If approved: Start your response with \"APPROVED:\" and briefly explain why"
  echo ""
  echo "Be concise but specific. Focus on real issues that would cause problems."
  echo ""
  if [ $LINT_FAILED -eq 1 ]; then
    echo "=== LINTING ERRORS ==="
    echo "$LINT_OUTPUT"
    echo ""
  fi
  if [ $TEST_FAILED -eq 1 ]; then
    echo "=== TEST FAILURES ==="
    echo "$TEST_OUTPUT"
    echo ""
  fi
  echo "=== STAGED CHANGES ==="
  git diff --staged
}

# Helper function: Run command with timeout and CLAUDECODE unset.
# Saves and restores the git index around the claude invocation so that
# any git operations performed by the AI reviewer session (e.g. staging
# marketplace/plugin files) cannot contaminate the staged changes.
run_with_timeout() {
  unset CLAUDECODE
  local index_file
  index_file=$(git rev-parse --git-path index)
  local index_backup="${index_file}.pre-review-backup"
  cp "$index_file" "$index_backup"
  timeout 90s "$@"
  local exit_code=$?
  cp "$index_backup" "$index_file"
  rm -f "$index_backup"
  return $exit_code
}

# Spawn independent Claude session for review
echo "   (Tip: Set SKIP_AI_REVIEW=1 to skip for quick commits)"
echo "   Spawning independent AI reviewer (90s timeout)..."

REVIEW_OUTPUT=$(build_review_input | run_with_timeout claude 2>&1)
REVIEW_EXIT_CODE=$?

# Check if timeout occurred
if [ $REVIEW_EXIT_CODE -eq 124 ]; then
    echo "⚠️  AI review timed out after 90 seconds"
    echo "   The commit will proceed, but manual review recommended"
    echo ""
    # Still enforce quality checks even on timeout
    if [ $LINT_FAILED -eq 1 ] || [ $TEST_FAILED -eq 1 ]; then
        echo "❌ Commit blocked: Quality checks failed"
        [ $LINT_FAILED -eq 1 ] && echo "   - Fix linting with: ./scripts/fix-lint.sh --unsafe"
        [ $TEST_FAILED -eq 1 ] && echo "   - Fix tests with: ./scripts/test.sh"
        exit 1
    fi
    echo "✓ All pre-commit checks passed!"
    exit 0
fi

# Check if review approved or has concerns
if echo "$REVIEW_OUTPUT" | grep -q "^APPROVED:"; then
    echo "✓ AI review approved"
    echo ""

    # Now check if linting or tests failed (after AI review)
    if [ $LINT_FAILED -eq 1 ]; then
        echo "❌ Commit blocked: Linting errors must be fixed"
        echo ""
        echo "$LINT_OUTPUT"
        echo ""
        echo "Fix with: ./scripts/fix-lint.sh --unsafe"
        exit 1
    fi

    if [ $TEST_FAILED -eq 1 ]; then
        echo "❌ Commit blocked: Tests must pass"
        echo ""
        echo "$TEST_OUTPUT" | tail -50
        echo ""
        echo "Run: ./scripts/test.sh to see full output"
        exit 1
    fi

    echo "✓ All pre-commit checks passed!"
    exit 0
elif echo "$REVIEW_OUTPUT" | grep -q "^CONCERNS:"; then
    echo "❌ AI review found concerns:"
    echo ""
    echo "$REVIEW_OUTPUT"
    echo ""
    echo "Please address the concerns or use 'git commit --no-verify' to skip checks."
    exit 1
else
    # If output doesn't match expected format, show it and continue
    echo "⚠️  AI review completed but output format unexpected"
    echo "   Review output:"
    echo "$REVIEW_OUTPUT"
    echo ""

    # Still enforce quality checks even if review format unexpected
    if [ $LINT_FAILED -eq 1 ] || [ $TEST_FAILED -eq 1 ]; then
        echo "❌ Commit blocked: Quality checks failed"
        [ $LINT_FAILED -eq 1 ] && echo "   - Fix linting with: ./scripts/fix-lint.sh --unsafe"
        [ $TEST_FAILED -eq 1 ] && echo "   - Fix tests with: ./scripts/test.sh"
        exit 1
    fi

    echo "✓ All pre-commit checks passed (proceeding anyway)"
    exit 0
fi
